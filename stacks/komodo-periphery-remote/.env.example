# Komodo-periphery accepts requests authenticated with these passkeys.
# Use the same value as komodo-core's KOMODO_PASSKEYS env so the Local
# (LXC 200) and remote periphery instances share one credential set —
# otherwise core needs a separate passkey per server.
#
# Comma-separated list, no quotes:
PERIPHERY_PASSKEY=replace-with-actual-passkey
